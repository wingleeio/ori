{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "noEmit": true,
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@wingleeio/ori-pretext": ["../../packages/pretext/src/index.ts"],
      "@wingleeio/ori-core": ["../../packages/core/src/index.ts"],
      "@wingleeio/ori-react": ["../../packages/react/src/index.ts"]
    }
  },
  "include": ["src", "vite.config.ts"],
  "exclude": ["dist", "node_modules"]
}
